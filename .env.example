# ============================================================
# AI Work Buddy 环境变量配置
# 复制此文件为 .env 并填入实际值
# 前端和后端共用此文件
# ============================================================

# ── 前端（Vite 构建）─────────────────────────────────────────
# API 基础路径，留空使用同源（Nginx 代理 /api/）
VITE_API_BASE=

# 开发环境代理目标（默认 http://localhost:3000）
VITE_PROXY_TARGET=

# ── 后端（Express 服务器）───────────────────────────────────
# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=buddy
DB_PASSWORD=NX62WP4bDJikBNih
DB_NAME=buddy

# 服务器端口
PORT=3000

# JWT 签名密钥（必填！生产环境请使用随机长字符串）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ai-work-buddy-development-secret-please-change-in-production

# API Key 可逆加密密钥（支持"再次查看明文"；生产必填，丢失则所有 key 退化为不可反查）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 注意：此值必须与 ecosystem.config.cjs 中 env.APIKEY_ENCRYPTION_KEY 保持一致
APIKEY_ENCRYPTION_KEY=ai-buddy-apikey-prod-please-change

# 离线下载统一根目录（服务端保存路径，默认 <项目>/data/offline）
# GV_OUTPUT=/www/wwwroot/buddy.bajiaolu.cn/data/offline
