# ============================================================
# AI Work Buddy 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# 生产环境数据库 API 地址
# 如果前端和 API 在同一域名下（Nginx 代理），留空即可
# 如果 API 在不同域名，填写完整的 PostgREST 地址（如 https://api.bajiaolu.cn）
VITE_SUPABASE_URL=

# PostgREST Anon Key（运行 deploy/generate-jwt.js 生成）
VITE_SUPABASE_ANON_KEY=
